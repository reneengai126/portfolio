## Part 3: Data Manipulation and Visualization

Wrangle *college_new* dataset to answer your research question. Then, plug it into ggplot and create a plot. 

```{r}
#data manipulation and visualization PLOT1 for Q1. 

#Filter by top public colleges
college_new %>%
    group_by(tot_minority)%>%
    arrange(total_enrollment, tot_minority)%>%
      select(type, total_enrollment, out_of_state_tuition, tot_minority)%>%
    filter(total_enrollment>1000)%>%
    filter(tot_minority>100)%>%
    mutate(new_total_enrollment=factor(total_enrollment))%>%
    ggplot(aes(x=out_of_state_tuition, y=tot_minority))+
      geom_point(color="pink",alpha=1)+
     labs(x="Out of State Tuition",y="Total Minority Population",title="Scatterplot of Out of State Tuition and Total Minority")+ 
    facet_grid(~type)+
      theme_bw()
   
```

```{r}
#data manipulation and visualization PLOT2 for Q2.

college_new %>%
    group_by(tot_minority, state)%>%
    arrange(asian, tot_minority)%>%
      select(degree_length, type, state, hispanic, tot_minority)%>%
     filter(tot_minority>=50)%>%
    mutate(new_tot_minority=factor(tot_minority))%>%
    ggplot(aes(x=type, y=hispanic))+
    geom_bar(stat="identity", aes(fill=type))+
    scale_fill_manual(values=c("Private"="blue","Public"="red","For Profit"="green"))+
   labs(x="College Type",y="Total Hispanic Population",title="Bar Graph of Total Hispanic Population Sorted by College Type")+ 
      facet_grid(~degree_length)+
  theme_bw() 
  
      
```

### Guideline
